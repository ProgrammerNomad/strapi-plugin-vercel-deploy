{
  "name": "@nomadprogrammer/strapi-plugin-vercel-deploy",
  "version": "0.1.0",
  "description": "Strapi v5 plugin to trigger and monitor deployments on Vercel",
  "license": "MIT",
  "author": "Shiv Singh <shiv@srapsware.com>",
  "keywords": [
    "strapi",
    "plugin",
    "vercel",
    "deploy",
    "deployment",
    "strapi5"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ProgrammerNomad/strapi-plugin-vercel-deploy.git"
  },
  "bugs": {
    "url": "https://github.com/ProgrammerNomad/strapi-plugin-vercel-deploy/issues"
  },
  "engines": {
    "node": ">=18.x.x <=22.x.x",
    "npm": ">=6.0.0"
  },
  "type": "commonjs",
  "exports": {
    "./package.json": "./package.json",
    "./strapi-admin": {
      "types": "./dist/admin/src/index.d.ts",
      "source": "./admin/src/index.ts",
      "import": "./dist/admin/index.mjs",
      "require": "./dist/admin/index.js",
      "default": "./dist/admin/index.js"
    },
    "./strapi-server": {
      "types": "./dist/server/src/index.d.ts",
      "source": "./server/src/index.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "strapi-plugin build",
    "watch": "strapi-plugin watch",
    "watch:link": "strapi-plugin watch:link",
    "verify": "strapi-plugin verify",
    "test:ts:front": "run -T tsc -p admin/tsconfig.json",
    "test:ts:back": "run -T tsc -p server/tsconfig.json"
  },
  "dependencies": {
    "axios": "^1.7.9"
  },
  "devDependencies": {
    "@strapi/strapi": "^5.8.0",
    "@strapi/design-system": "^2.0.0-rc.30",
    "@strapi/icons": "^2.0.0-rc.30",
    "@strapi/sdk-plugin": "^6.0.0",
    "@strapi/typescript-utils": "^5.8.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "ajv": "^8.18.0",
    "prettier": "^3.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-intl": "^6.0.0",
    "react-router-dom": "^6.30.3",
    "styled-components": "^6.3.11",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@strapi/design-system": "^2.0.0-rc.0",
    "@strapi/icons": "^2.0.0-rc.0",
    "@strapi/strapi": "^5.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.0.0",
    "styled-components": "^6.0.0"
  },
  "strapi": {
    "kind": "plugin",
    "name": "vercel-deploy",
    "displayName": "Vercel Deploy",
    "description": "Plugin to trigger and monitor deployments on Vercel"
  }
}
